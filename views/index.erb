<h1><%=session[:username]%>'s Contacts:</h1>

<section>
  <h3>Family</h3>
  <ul>
    <% session[:contact_list][:family].keys.each do |member|%>
      <li>
        <a href="/:<%=member%>"><%=member.capitalize%></a>
      </li>
    <%end%>
  </ul>
</section>

<section>
  <h3>Friends</h3>
  <ul>
    <% session[:contact_list][:friends].keys.each do |friend|%>
      <li>
        <a href="/:<%=friend%>"><%=friend.capitalize%></a>
      </li>
    <%end%>
  </ul>
</section>

<section>
  <h3>Work</h3>
  <ul>
    <% session[:contact_list][:work].keys.each do |friend|%>
      <li>
        <a href="/:<%=friend%>"><%=friend.capitalize%></a>
      </li>
    <%end%>
  </ul>
</section>
